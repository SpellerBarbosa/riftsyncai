# Riot Games API Key
# Obtenha sua chave em: https://developer.riotgames.com/
RIOT_API_KEY=

# Token de acesso à SpellCoach API v2 (dados de meta, builds, matchups)
API_ACCESS_TOKEN=

# Token de acesso à API do Vercel (sincronização interna)
# Utilizado como fallback pelo vercel_sync_service
API_VERCEL_TOKEN=

# Groq API Key (inferência ultrarrápida com Llama 3)
# Obtenha sua chave gratuita em: https://console.groq.com/keys
GROQ_API_KEY=
